# 复制为 .env 后修改
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/tech_admin
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# 本地上传根目录；其下按业务域分子目录（见 upload_paths / POST /files/upload）
UPLOAD_DIR=./data/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 可选：uv run serve 时使用
# BIND_HOST=0.0.0.0
# PORT=8000
